{
  "name": "@blazarbox/blazarcoder",
  "version": "0.1.0",
  "description": "Type-safe blazarcoder bindings (config + CLI helpers) for BlazarUI integration.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "bun x tsc -p tsconfig.json",
    "lint": "bun x tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "prepare": "bun run build"
  },
  "dependencies": {
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "typescript": "^5.9.3"
  },
  "license": "GPL-3.0",
  "keywords": [
    "blazarcoder",
    "srt",
    "gstreamer",
    "blazarbox",
    "config",
    "cli"
  ]
}
